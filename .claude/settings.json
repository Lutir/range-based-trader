{
  "permissions": {
    "allow": [
      "Bash(git add -A && git commit *)",
      "Bash(git add * && git commit *)",
      "Bash(git commit -m *)",
      "Bash(git init *)",
      "Bash(git add *)",
      "Bash(mkdir *)",
      "Bash(pip install *)",
      "Bash(python -m pytest *)",
      "Bash(python -m range_scanner *)",
      "Bash(python3 -m pytest *)",
      "Bash(rm -f charts/*)",
      "Bash(rm -f results/*)",
      "WebFetch(domain:docs.alpaca.markets)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:finnhub.io)",
      "mcp__memory__*",
      "mcp__brave-search__*"
    ]
  },
  "mcpServers": {
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    },
    "brave-search": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": ""
      }
    }
  }
}
